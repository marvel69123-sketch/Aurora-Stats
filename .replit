modules = ["nodejs-24", "python-3.12"]

[nix]
channel = "stable-25_05"
packages = ["python313Packages.pytest_7"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

# Prevent browsers/CDNs from keeping a stale SPA shell that points at old hashed assets
[[deployment.responseHeaders]]
path = "/index.html"
name = "Cache-Control"
value = "no-cache, no-store, must-revalidate"

[[deployment.responseHeaders]]
path = "/"
name = "Cache-Control"
value = "no-cache, no-store, must-revalidate"

[[deployment.responseHeaders]]
path = "/aurora-ui-build.txt"
name = "Cache-Control"
value = "no-cache, no-store, must-revalidate"

# Use Replit-bundled pnpm only — never Corepack/pnpm self-download of pnpm@9.x
[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true", "COREPACK_ENABLE_STRICT" = "0", "COREPACK_ENABLE_AUTO_PIN" = "0", "COREPACK_ENABLE_DOWNLOAD_PROMPT" = "0" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

# ── Official layout (do not invert) ──────────────────────────────────────────
# Root package.json = monorepo "workspace" only.
# Frontend SoT: artifacts/web   (vite/tsconfig/src/public stay THERE)
# Backend SoT:  artifacts/aurora (start.sh → uvicorn :8080)
# Replit API artifact file: artifacts/api-server/.replit-artifact/artifact.toml
#   → runs code from artifacts/aurora (historical ID; do not relocate randomly)
# Optional mirror: aurora/  ← bash scripts/sync-aurora-mirror.sh
# Before install/build: bash scripts/verify-layout.sh
